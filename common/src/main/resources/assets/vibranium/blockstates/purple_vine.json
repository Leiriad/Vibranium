{
  "multipart": [
    { "when": { "north": "true" }, "apply": { "model": "vibranium:block/purple_vine" } },
    { "when": { "east": "true" },  "apply": { "model": "vibranium:block/purple_vine", "y": 90 } },
    { "when": { "south": "true" }, "apply": { "model": "vibranium:block/purple_vine", "y": 180 } },
    { "when": { "west": "true" },  "apply": { "model": "vibranium:block/purple_vine", "y": 270 } },
    { "when": { "up": "true" },    "apply": { "model": "vibranium:block/purple_vine", "x": 270 } }
  ]
}