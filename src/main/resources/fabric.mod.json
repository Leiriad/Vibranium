{
	"schemaVersion": 1,
	"id": "vibranium",
	"version": "${version}",
	"name": "Vibranium",
	"description": "Bringing the strength of vibranium ore to Minecraft",
	"authors": [
		"Leiriad Jenkins"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/vibranium/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"vibranium.Vibranium"
		],
		"client": [
			"vibranium.VibraniumClient"
		],
		"fabric-datagen": [
			"vibranium.VibraniumDataGenerator"
		]
	},
	"mixins": [
		"vibranium.mixins.json",
		{
			"config": "vibranium.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}